# =============================================================================
# Sadar Bencana - example environment
#
# Copy this file to ".env" for docker compose or ".env.local" for local scripts.
# All values below are placeholders. Replace them before running any real use.
# =============================================================================

# --- Supabase / PostgreSQL production database ---
# Use the Supabase pooled connection string, not a local Docker PostgreSQL URL.
# Example host pattern: aws-*-*.pooler.supabase.com
DATABASE_URL=postgresql://postgres.<project-ref>:replace-with-db-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Supabase Auth ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
# Optional. If unset, the API derives it from SUPABASE_URL.
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# --- Redis (used by worker for runtime coordination/cache) ---
# Docker compose default can use redis://redis:6379. Production can use a managed Redis.
REDIS_URL=redis://redis:6379

# --- Worker / LLM ---
LLM_BASE_URL=http://host.docker.internal:8080
LLM_TIMEOUT=180
LLM_MODEL=gemma4-e4b
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API ---
API_ENV=docker
MASTRA_BASE_URL=http://host.docker.internal:4111
RISK_FREE_LIMIT=0
AI_BRIEFING_TIMEOUT=150s

# --- Frontend build/runtime ---
VITE_API_BASE_URL=/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# --- CORS (production only) ---
# Comma-separated list of allowed origins.
# Example: CORS_ALLOWED_ORIGINS=https://sadarbencana.id,https://www.sadarbencana.id
CORS_ALLOWED_ORIGINS=
