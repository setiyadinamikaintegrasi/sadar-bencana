# App identity
APP_NAME=Reinsurance Risk Monitor
APP_ENV=local

# Frontend
WEB_PORT=3001
VITE_API_BASE_URL=http://localhost:8001/api/v1

# Backend
API_PORT=8001
API_HOST=0.0.0.0
WORKER_PORT=8002

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reinsurance_risk_monitor
REDIS_URL=redis://localhost:6379/0

# AI / summarization
LLM_MODE=local
LLM_API_BASE_URL=http://localhost:8080/v1
LLM_MODEL=gemma-4-e4b
LLM_API_KEY=change-me-if-required

# Data sources
BMKG_BASE_URL=https://data.bmkg.go.id
USGS_BASE_URL=https://earthquake.usgs.gov
GDACS_BASE_URL=https://www.gdacs.org
NEWS_FEED_ENABLED=true
INTERNAL_DATA_MODE=mock

# Security
JWT_SECRET=change-this-in-local-env
