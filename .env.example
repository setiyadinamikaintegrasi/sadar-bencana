# =============================================================================
# Reinsurance Risk Monitor - example environment for docker compose
#
# Copy this file to ".env" and adjust the values before running:
#     cp .env.example .env
#
# All values below are DEVELOPMENT PLACEHOLDERS. Replace them for any real use.
# =============================================================================

# --- PostgreSQL bootstrap (consumed by the postgres image) ---
POSTGRES_USER=rrm
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_DB=reinsurance_risk_monitor

# --- Internal DATABASE_URL (used by api + worker inside the Docker network) ---
# The host MUST be the compose service name "postgres" (not localhost).
# The password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgres://rrm:changeme_pg_password@postgres:5432/reinsurance_risk_monitor

# --- Redis (internal Docker network URL) ---
REDIS_URL=redis://redis:6379

# --- API runtime ---
API_HOST=0.0.0.0
API_PORT=8001
API_ENV=docker

# --- Worker LLM integration ---
# llama.cpp runs on the HOST at localhost:8080. Containers reach it through
# the host-gateway mapped via extra_hosts in docker-compose.yml.
LLM_BASE_URL=http://host.docker.internal:8080
LLM_TIMEOUT=180
LLM_MODEL=gemma4-e4b

# --- Web build-time API base URL ---
# "/api/v1" keeps browser traffic on the nginx origin, which proxies /api to the API container.
VITE_API_BASE_URL=/api/v1

# --- Optional Telegram alert delivery (leave blank to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- M9: AISStream.io maritime vessel tracking (WebSocket) ---
# Register at https://aisstream.io/ to get a free API key.
# Leave blank to disable vessel tracking (OpenSky aviation still works).
AISSTREAM_API_KEY=

# --- M9: OpenSky Network aviation tracking ---
# Free tier (anonymous) works without credentials.
# For higher rate limits, register at https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
